# Local development uses Vite's proxy and can leave this blank.
# In production (Cloudflare Pages), set this to your deployed backend
# URL with /api on the end. The live Render service is named "toy-mall"
# from the original repo — the project rebrand kept the service name
# for git/billing continuity, so the URL stays as below.
# Example: VITE_API_URL=https://toy-mall.onrender.com/api

VITE_API_URL=
